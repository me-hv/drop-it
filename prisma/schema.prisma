datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          String   @id @default(cuid())
  name        String?
  email       String   @unique
  handle      String?  @unique
  avatar      String?
  banner      String?
  image       String?  // Legacy compatibility
  coverImage  String?  // Legacy compatibility
  bio         String?
  location    String?
  website     String?
  birthDate   String?
  drops       Drop[]
  totalDrops  Int      @default(0)
  totalPosts  Int      @default(0)
  posts       Post[]
  streak      Int      @default(0)
  followers   Follow[] @relation("following")
  following   Follow[] @relation("follower")
  pollVotes   PollVote[]
  savedDrops  SavedDrop[]
  createdAt   DateTime @default(now())
}

model Follow {
  follower    User @relation("follower", fields: [followerId], references: [id])
  followerId  String
  following   User @relation("following", fields: [followingId], references: [id])
  followingId String

  @@id([followerId, followingId])
}

model Drop {
  id          String   @id @default(cuid())
  text        String?
  mediaUrl    String?
  mediaType   String?  // e.g., "audio", "video", "image"
  duration    Int      @default(0) // duration in seconds for media
  vibe        String   // e.g., "Hustle", "Deep", "Chill"
  caption     String?  // AI-generated
  author      User     @relation(fields: [authorId], references: [id])
  authorId    String
  isPermanent Boolean  @default(false)
  createdAt   DateTime @default(now())
  saves       Int      @default(0)
  reDrops     Int      @default(0)
  tips        Float    @default(0)
  pollOptions String?  // JSON stringified array of poll options
  pollEndsAt  DateTime? // When the poll ends
  pollVotes   PollVote[]
  location    String?  // Tagged location
  isPinned    Boolean  @default(false)
  quotedId    String?
  quoted      Drop?    @relation("QuoteRelation", fields: [quotedId], references: [id])
  quotes      Drop[]   @relation("QuoteRelation")
  savedDrops  SavedDrop[]
}

model PollVote {
  id        String   @id @default(cuid())
  dropId    String
  drop      Drop     @relation(fields: [dropId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  optionIdx Int      // The index of the selected option
  createdAt DateTime @default(now())

  @@unique([dropId, userId])
}

model Post {
  id          String   @id @default(cuid())
  text        String
  mediaUrl    String?
  mediaType   String?
  metadata    String?  // JSON stringified metadata (e.g., location, polls)
  author      User     @relation(fields: [authorId], references: [id])
  authorId    String
  pinned      Boolean  @default(false)
  likes       Int      @default(0)
  createdAt   DateTime @default(now())
}

model SavedDrop {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dropId    String
  drop      Drop     @relation(fields: [dropId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, dropId])
}
